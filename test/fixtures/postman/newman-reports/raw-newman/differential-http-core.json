            "script": {
              "id": "2c8fef2d-211e-49fc-a272-e4f9ae075148",
              "type": "text/javascript",
              "exec": [
                "pm.test('core response status and body', function () {",
                "  pm.response.to.have.status(200);",
                "  pm.expect(pm.response.headers.get('content-type')).to.include('application/json');",
                "  var body = pm.response.json();",
                "  pm.expect(body.path).to.equal('/json');",
                "  pm.expect(body.xPre).to.equal('local-1');",
                "  pm.expect(pm.collectionVariables.get('collectionTouched')).to.equal('yes');",
                "});",
                "pm.test('pm.info exposes core metadata', function () {",
                "  pm.expect(pm.info.eventName).to.equal('test');",
                "  pm.expect(pm.info.requestName).to.equal('Core JSON');",
                "  pm.expect(pm.info.iteration).to.equal(0);",
                "});",
                "pm.sendRequest(pm.variables.replaceIn('{{baseUrl}}/aux'), function (error, response) {",
                "  pm.test('pm.sendRequest callback receives response', function () {",
                "    pm.expect(error).to.equal(null);",
                "    pm.expect(response.code).to.equal(200);",
                "    pm.expect(response.json().aux).to.equal(true);",
                "  });",
                "});"
              ],
              "_lastExecutionId": "8213592c-52ae-42bb-bf4e-e9291845358b"
            }
          }

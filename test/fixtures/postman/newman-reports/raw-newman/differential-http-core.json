              "exec": [
                "pm.variables.set('localToken', 'local-1');",
                "pm.environment.set('envToken', 'env-1');",
                "pm.collectionVariables.set('collectionTouched', 'yes');",
                "pm.request.headers.upsert({ key: 'X-Pre', value: pm.variables.get('localToken') });"

            "script": {
              "id": "8e57c31e-47bd-4c2e-bedf-d46b1ab26779",
              "type": "text/javascript",
              "exec": [
                "var summary = {",
                "  promiseMicrotask: false,",
                "  timeout: false,",
                "  intervalCleared: false,",
                "  intervalCountAtLeastTwo: false,",
                "  visualizerSet: false,",
                "  timerFunctions: [typeof setTimeout, typeof clearTimeout, typeof setInterval, typeof clearInterval].join(','),",
                "  consoleFunctions: [typeof console.log, typeof console.warn, typeof console.error].join(',')",
                "};",
                "console.log('runtime limit probe %s', 'start');",
                "console.warn({ runtime: 'limits', ok: true });",
                "Promise.resolve().then(function () {",
                "  summary.promiseMicrotask = true;",
                "});",
                "var intervalCount = 0;",
                "var interval = setInterval(function () {",
                "  intervalCount += 1;",
                "  if (intervalCount >= 2) {",
                "    clearInterval(interval);",
                "    summary.intervalCleared = true;",
                "  }",
                "}, 1);",
                "setTimeout(function () {",
                "  summary.timeout = true;",
                "  summary.intervalCountAtLeastTwo = intervalCount >= 2;",
                "  pm.visualizer.set('<section>{{label}}</section>', { label: 'runtime' });",
                "  summary.visualizerSet = true;",
                "  pm.environment.set('runtimeLimitsSummary', JSON.stringify(summary));",
                "  pm.test('runtime timers, console, and visualizer work below policy limits', function () {",
                "    pm.expect(summary.promiseMicrotask).to.equal(true);",
                "    pm.expect(summary.timeout).to.equal(true);",
                "    pm.expect(summary.intervalCleared).to.equal(true);",
                "    pm.expect(summary.intervalCountAtLeastTwo).to.equal(true);",
                "    pm.expect(summary.visualizerSet).to.equal(true);",
                "    pm.expect(summary.timerFunctions).to.equal('function,function,function,function');",
                "    pm.expect(summary.consoleFunctions).to.equal('function,function,function');",
                "  });",
                "}, 25);"
              ],
              "_lastExecutionId": "a17cbdb9-643b-4545-95d6-04fac8ac4a9b"
            }
          }
        ]

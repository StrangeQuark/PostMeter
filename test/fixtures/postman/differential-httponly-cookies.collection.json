{
  "info": {
    "name": "PostMeter Differential HttpOnly Cookies",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "00000000-0000-4000-8000-000000000205"
  },
  "item": [
    {
      "name": "Seed HttpOnly Cookies",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/cookie-check"
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var baseUrl = pm.variables.replaceIn('{{baseUrl}}');",
              "var jar = pm.cookies.jar();",
              "pm.test('seed scripted visible and httponly cookies', function (done) {",
              "  jar.set(baseUrl, 'visible', 'visible-value', function (visibleError) {",
              "    if (visibleError) { done(visibleError); return; }",
              "    jar.set(baseUrl, { name: 'secret', value: 'secret-value', httpOnly: true, path: '/' }, function (secretError) {",
              "      if (secretError) { done(secretError); return; }",
              "      jar.set(baseUrl, { name: 'replaceMe', value: 'server-secret', httpOnly: true, path: '/' }, function (replaceError) {",
              "        if (replaceError) { done(replaceError); return; }",
              "        jar.set(baseUrl, { name: 'clearMe', value: 'clear-secret', httpOnly: true, path: '/' }, function (clearError) {",
              "          done(clearError || undefined);",
              "        });",
              "      });",
              "    });",
              "  });",
              "});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('httponly seed request sends scripted cookies', function () {",
              "  pm.response.to.have.status(200);",
              "  var cookies = pm.response.json().cookies;",
              "  pm.expect(cookies.visible).to.equal('visible-value');",
              "  pm.expect(cookies.secret).to.equal('secret-value');",
              "  pm.expect(cookies.replaceMe).to.equal('server-secret');",
              "  pm.expect(cookies.clearMe).to.equal('clear-secret');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Read And Mutate HttpOnly Cookies",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/cookie-check"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var baseUrl = pm.variables.replaceIn('{{baseUrl}}');",
              "var jar = pm.cookies.jar();",
              "pm.test('httponly cookies are readable through current helpers and jar helpers', function (done) {",
              "  try {",
              "    var requestCookies = pm.response.json().cookies;",
              "    pm.expect(requestCookies.secret).to.equal('secret-value');",
              "    pm.expect(pm.cookies.get('secret')).to.equal('secret-value');",
              "    pm.expect(pm.cookies.has('secret')).to.equal(true);",
              "    pm.expect(pm.cookies.toObject().secret).to.equal('secret-value');",
              "  } catch (error) {",
              "    done(error);",
              "    return;",
              "  }",
              "  jar.get(baseUrl, 'secret', function (getError, value) {",
              "    try {",
              "      pm.expect(getError).to.equal(null);",
              "      pm.expect(value).to.equal('secret-value');",
              "    } catch (error) {",
              "      done(error);",
              "      return;",
              "    }",
              "    jar.getAll(baseUrl, function (allError, cookies) {",
              "      try {",
              "        pm.expect(allError).to.equal(null);",
              "        pm.expect(cookies.get('secret')).to.equal('secret-value');",
              "        pm.expect(cookies.one('secret').httpOnly).to.equal(true);",
              "        done();",
              "      } catch (error) {",
              "        done(error);",
              "      }",
              "    });",
              "  });",
              "});",
              "pm.test('httponly jar mutations and pm.sendRequest updates match Postman', function (done) {",
              "  jar.set(baseUrl, { name: 'scriptSecret', value: 'script-secret', httpOnly: true, path: '/' }, function (setError) {",
              "    if (setError) { done(setError); return; }",
              "    jar.get(baseUrl, 'scriptSecret', function (getError, value) {",
              "      try {",
              "        pm.expect(getError).to.equal(null);",
              "        pm.expect(value).to.equal('script-secret');",
              "      } catch (error) {",
              "        done(error);",
              "        return;",
              "      }",
              "      jar.set(baseUrl, 'replaceMe', 'client-visible', function (replaceError) {",
              "        if (replaceError) { done(replaceError); return; }",
              "        jar.unset(baseUrl, 'clearMe', function (unsetError) {",
              "          if (unsetError) { done(unsetError); return; }",
              "          pm.sendRequest(baseUrl + '/set-send-httponly', function (sendError, response) {",
              "            try {",
              "              pm.expect(sendError).to.equal(null);",
              "              pm.expect(response.code).to.equal(200);",
              "            } catch (error) {",
              "              done(error);",
              "              return;",
              "            }",
              "            jar.get(baseUrl, 'sendSecret', function (sendGetError, sendValue) {",
              "              try {",
              "                pm.expect(sendGetError).to.equal(null);",
              "                pm.expect(sendValue).to.equal('send-secret');",
              "                done();",
              "              } catch (error) {",
              "                done(error);",
              "              }",
              "            });",
              "          });",
              "        });",
              "      });",
              "    });",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "After HttpOnly Mutations",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/cookie-check"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var baseUrl = pm.variables.replaceIn('{{baseUrl}}');",
              "var jar = pm.cookies.jar();",
              "pm.test('httponly mutations affect later requests', function () {",
              "  var cookies = pm.response.json().cookies;",
              "  pm.expect(cookies.visible).to.equal('visible-value');",
              "  pm.expect(cookies.secret).to.equal('secret-value');",
              "  pm.expect(cookies.replaceMe).to.equal('client-visible');",
              "  pm.expect(cookies.scriptSecret).to.equal('script-secret');",
              "  pm.expect(cookies.sendSecret).to.equal('send-secret');",
              "  pm.expect(cookies.clearMe).to.equal(undefined);",
              "});",
              "pm.test('httponly jar clear removes visible and httponly cookies', function (done) {",
              "  jar.clear(baseUrl, function (error) {",
              "    try {",
              "      pm.expect(error).to.equal(null);",
              "      done();",
              "    } catch (assertion) {",
              "      done(assertion);",
              "    }",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "After HttpOnly Clear",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/cookie-check"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('httponly clear removed every in-scope cookie', function () {",
              "  var cookies = pm.response.json().cookies;",
              "  pm.expect(cookies).to.deep.equal({});",
              "  pm.environment.set('httpOnlyCookieSummary', JSON.stringify({ readable: true, mutable: true, clearRemovedAll: true }));",
              "});"
            ]
          }
        }
      ]
    }
  ]
}

                  "  const response = await pm.execution.runRequest('03c RunRequest Target', { variables: { runRequestPath: 'run-request-target' } });",
                  "  pm.expect(response.code).to.equal(202);",
                  "  pm.expect(response.json().target).to.equal('run-request-target');",
                  "  pm.expect(pm.environment.get('runRequestTarget')).to.equal('yes');",
                  "});",
                  "pm.execution.setNextRequest('04 Execution Jump Start');"
                ]

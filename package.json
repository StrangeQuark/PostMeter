{
  "name": "postmeter",
  "version": "0.2.0",
  "description": "Electron desktop API client for local API workflows.",
  "author": "StrangeQuark <support@qrksw.com>",
  "homepage": "https://github.com/StrangeQuark/PostMeter#readme",
  "bugs": {
    "url": "https://github.com/StrangeQuark/PostMeter/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/StrangeQuark/PostMeter.git"
  },
  "main": "electron/main.js",
  "type": "commonjs",
  "license": "GPL-3.0-only",
  "scripts": {
    "prestart": "node scripts/ensureElectronRuntime.js --repair",
    "start": "electron .",
    "pretest": "node scripts/ensureElectronRuntime.js --repair && node scripts/buildWindowsSandboxHelper.js --if-supported",
    "test": "node scripts/runElectronTests.js",
    "renderer:html:write": "node scripts/buildRendererHtml.js --write",
    "renderer:html:check": "node scripts/buildRendererHtml.js --check",
    "renderer:security:validate": "node scripts/validateRendererSecurity.js",
    "github:workflows:validate": "node scripts/validateGithubWorkflows.js",
    "secrets:validate": "node scripts/validateSecrets.js",
    "release:governance:validate": "node scripts/validateReleaseGovernance.js",
    "refactor:structure:validate": "node scripts/validateRefactorStructure.js",
    "test:smoke": "node test/electron/startupSmoke.js",
    "test:ui": "node test/electron/uiWorkflowSmoke.js",
    "test:ui:regression": "node test/electron/uiRegressionSmoke.js",
    "test:ui:typography": "node test/electron/uiTypographySmoke.js",
    "test:ui:oauth": "node test/electron/uiOauthSmoke.js",
    "test:ui:hawk": "node test/electron/uiHawkSmoke.js",
    "test:ui:aws": "node test/electron/uiAwsSmoke.js",
    "test:ui:a11y": "node test/electron/uiA11ySmoke.js",
    "test:ui:auth": "node test/electron/uiAuthMatrixSmoke.js",
    "test:ui:snapshot": "node test/electron/uiSnapshotSmoke.js",
    "cli": "node scripts/postmeter-cli.js",
    "precheck": "node scripts/ensureElectronRuntime.js --repair && npm run native:windows-sandbox:build",
    "check": "npm test && npm run renderer:html:check && npm run renderer:security:validate && npm run github:workflows:validate && npm run secrets:validate && npm run release:governance:validate && npm run refactor:structure:validate && npm run sandbox:validate && npm run sandbox:platform:validate && npm run postman:parity:validate && npm run postman:docs:validate && npm run postman:newman-reports:validate && npm run oauth:certify:validate && npm run oauth:certify:mock && npm run production:readiness:validate && npm run electron:security:validate && npm run workspace:durability:validate && npm run compatibility:non-postman:validate && npm run ux:accessibility:validate && npm run diagnostics:privacy:validate && npm run release:gate && npm run test:smoke && npm run test:ui && npm run test:ui:regression && npm run test:ui:typography && npm run test:ui:oauth && npm run test:ui:hawk && npm run test:ui:aws && npm run test:ui:a11y && npm run test:ui:auth && npm run test:ui:snapshot && npm audit --audit-level=high && npm run electron:version",
    "electron:version": "node scripts/electronVersion.js",
    "native:windows-sandbox:build": "node scripts/buildWindowsSandboxHelper.js",
    "sandbox:validate": "node scripts/validateSandboxRuntime.js",
    "sandbox:validate:packaged": "node scripts/validatePackagedSandboxRuntime.js",
    "sandbox:platform:validate": "node scripts/osSandboxPlatformMatrix.js validate",
    "sandbox:platform:write": "node scripts/osSandboxPlatformMatrix.js write-matrix",
    "sandbox:platform:claim": "node scripts/osSandboxPlatformMatrix.js claim",
    "postman:parity:validate": "node scripts/postmanParityHarness.js validate",
    "postman:parity:write": "node scripts/postmanParityHarness.js write-matrix",
    "postman:parity:claim": "node scripts/postmanParityHarness.js claim",
    "postman:parity:diff": "node scripts/postmanParityHarness.js diff",
    "postman:docs:validate": "node scripts/postmanDocsCoverageAudit.js validate",
    "postman:docs:write": "node scripts/postmanDocsCoverageAudit.js write --live",
    "postman:docs:live": "node scripts/postmanDocsCoverageAudit.js live",
    "postman:newman-reports:refresh": "node scripts/newmanReports.js refresh",
    "postman:newman-reports:write": "node scripts/newmanReports.js write",
    "postman:newman-reports:validate": "node scripts/newmanReports.js validate",
    "oauth:certify:validate": "node scripts/oauthProviderCertification.js validate",
    "oauth:certify:write": "node scripts/oauthProviderCertification.js write-matrix",
    "oauth:certify:mock": "node scripts/oauthProviderCertification.js mock",
    "oauth:certify:live": "node scripts/oauthProviderCertification.js live",
    "production:readiness": "node scripts/productionReadiness.js status",
    "production:readiness:write": "node scripts/productionReadiness.js write",
    "production:readiness:validate": "node scripts/productionReadiness.js validate",
    "production:readiness:claim": "node scripts/productionReadiness.js claim",
    "production:readiness:claim:beta": "node scripts/productionReadiness.js claim --level=beta",
    "production:readiness:claim:rc": "node scripts/productionReadiness.js claim --level=rc",
    "production:readiness:claim:stable": "node scripts/productionReadiness.js claim --level=stable",
    "electron:security:write": "node scripts/productionSupportMatrix.js electron-security write",
    "electron:security:validate": "node scripts/productionSupportMatrix.js electron-security validate",
    "workspace:durability:write": "node scripts/productionSupportMatrix.js workspace-durability write",
    "workspace:durability:validate": "node scripts/productionSupportMatrix.js workspace-durability validate",
    "compatibility:non-postman:write": "node scripts/productionSupportMatrix.js non-postman-compatibility write",
    "compatibility:non-postman:validate": "node scripts/productionSupportMatrix.js non-postman-compatibility validate",
    "ux:accessibility:write": "node scripts/productionSupportMatrix.js ux-accessibility write",
    "ux:accessibility:validate": "node scripts/productionSupportMatrix.js ux-accessibility validate",
    "diagnostics:privacy:write": "node scripts/productionSupportMatrix.js diagnostics-privacy write",
    "diagnostics:privacy:validate": "node scripts/productionSupportMatrix.js diagnostics-privacy validate",
    "pack:linux": "electron-builder --linux dir --publish never",
    "dist:linux": "electron-builder --linux AppImage deb --publish never",
    "dist:win": "npm run native:windows-sandbox:build && electron-builder --win nsis --publish never",
    "dist:mac": "electron-builder --mac dmg zip --publish never",
    "release:checksums": "node scripts/writeReleaseChecksums.js",
    "release:manifest": "node scripts/writeReleaseManifest.js",
    "release:prepare": "npm run release:checksums && npm run release:manifest",
    "release:gate": "node scripts/validateSandboxReleaseGate.js",
    "release:validate": "node scripts/validateReleaseArtifacts.js",
    "release:validate:packaged-smoke": "node scripts/validatePackagedAppSmoke.js",
    "release:validate:packaged-workflow": "node scripts/validatePackagedWorkflowSmoke.js",
    "release:validate:packaged-auth": "node scripts/validatePackagedAuthSmoke.js",
    "release:validate:win-protocol": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/validateWindowsProtocolRegistration.ps1",
    "release:validate:mac-protocol": "bash scripts/validateMacProtocolRegistration.sh"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.strangequark.postmeter",
    "productName": "PostMeter",
    "icon": "build/icon.png",
    "protocols": [
      {
        "name": "PostMeter OAuth Callback",
        "schemes": [
          "postmeter"
        ]
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "StrangeQuark",
        "repo": "PostMeter",
        "releaseType": "release"
      }
    ],
    "files": [
      "electron/**/*",
      "src/**/*",
      "build/icon.png",
      "package.json",
      "LICENSE",
      "README.md"
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "icon": "build/icons",
      "category": "Development",
      "maintainer": "StrangeQuark <support@qrksw.com>",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "deb": {
      "afterRemove": "build/linux-after-remove.tpl",
      "fpm": [
        "--before-remove=build/linux-before-remove.tpl"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "extraResources": [
        {
          "from": "native/windows-sandbox-helper/bin/PostMeterWindowsSandboxHelper.exe",
          "to": "native/windows/PostMeterWindowsSandboxHelper.exe"
        }
      ],
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "include": "build/installer.nsh",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@grpc/proto-loader": "^0.8.1",
    "@xmldom/xmldom": "^0.9.10",
    "electron-updater": "^6.8.3",
    "handlebars": "4.7.9",
    "markdown-it": "^14.1.1",
    "node-forge": "^1.4.0",
    "node-html-parser": "^7.1.0",
    "psl": "^1.15.0",
    "xpath": "^0.0.34",
    "yaml": "^2.9.0"
  },
  "overrides": {
    "ip-address": "10.2.0"
  }
}
